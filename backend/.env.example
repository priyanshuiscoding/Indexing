TESSERACT_LANG=hin+eng
ENABLE_HANDWRITTEN_HINDI_ASSIST=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/court_rag
WORKFLOW_SQLITE_PATH=./workflow.db
